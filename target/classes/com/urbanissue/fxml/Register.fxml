<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.urbanissue.controller.RegisterController"
     alignment="CENTER" spacing="12" styleClass="form-root"
     prefWidth="400" prefHeight="420">
    <padding><Insets top="20" right="24" bottom="20" left="24"/></padding>
    <Label text="Create Account" styleClass="title-label"/>
    <TextField fx:id="nameField" promptText="Full name" maxWidth="280" prefHeight="32"/>
    <TextField fx:id="emailField" promptText="Email" maxWidth="280" prefHeight="32"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="280" prefHeight="32"/>
    <TextField fx:id="phoneField" promptText="Phone (optional)" maxWidth="280" prefHeight="32"/>
    <ComboBox fx:id="roleCombo" promptText="Role" maxWidth="280" prefHeight="32"/>
    <Button fx:id="registerButton" text="Register" onAction="#handleRegister" defaultButton="true" prefWidth="140"/>
    <Button fx:id="backButton" text="Back to Login" onAction="#handleBack" prefWidth="140"/>
    <Label fx:id="messageLabel" styleClass="message-label" wrapText="true" visible="false" managed="false"/>
</VBox>
