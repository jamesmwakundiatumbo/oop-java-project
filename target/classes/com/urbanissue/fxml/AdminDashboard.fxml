<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.urbanissue.controller.AdminDashboardController"
     styleClass="main-container" spacing="0" prefWidth="1200" prefHeight="800">

    <!-- Modern header bar -->
    <HBox styleClass="header-bar" alignment="CENTER_LEFT" spacing="16">
        <Label fx:id="welcomeLabel" text="Admin Dashboard" styleClass="welcome-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="User guide" onAction="#handleUserGuide" styleClass="button-secondary"/>
        <Button fx:id="logoutButton" text="Sign Out" onAction="#handleLogout" styleClass="button-secondary"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS">
        <Tab text="All Issues" closable="false">
            <VBox styleClass="card" spacing="20" style="-fx-padding: 24;">
                <Label text="Issue Management" styleClass="section-label"/>

                <!-- Filter Controls -->
                <VBox spacing="12">
                    <Label text="Filters" styleClass="metric-title"/>
                    <HBox spacing="16" alignment="CENTER_LEFT">
                        <VBox spacing="4">
                            <Label text="Category:" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                            <ComboBox fx:id="categoryFilterCombo" promptText="All Categories" prefWidth="150"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Status:" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                            <ComboBox fx:id="statusFilterCombo" promptText="All Statuses" prefWidth="150"/>
                        </VBox>
                        <VBox spacing="4">
                            <Label text="Priority:" style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                            <ComboBox fx:id="priorityFilterCombo" promptText="All Priorities" prefWidth="150"/>
                        </VBox>
                        <VBox spacing="4" alignment="BOTTOM_LEFT">
                            <Label text=" " style="-fx-font-size: 12px;"/>
                            <HBox spacing="8">
                                <Button fx:id="applyFiltersButton" text="Apply Filters" onAction="#handleApplyFilters" styleClass="button-secondary"/>
                                <Button fx:id="clearFiltersButton" text="Clear" onAction="#handleClearFilters" styleClass="button-secondary"/>
                            </HBox>
                        </VBox>
                    </HBox>
                </VBox>

                <TableView fx:id="issuesTable" VBox.vgrow="ALWAYS" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="titleCol" text="Title" prefWidth="220"/>
                        <TableColumn fx:id="categoryCol" text="Category" prefWidth="130"/>
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="110"/>
                        <TableColumn fx:id="priorityCol" text="Priority" prefWidth="90"/>
                        <TableColumn fx:id="reportedByCol" text="Reported By" prefWidth="140"/>
                        <TableColumn fx:id="assignedCol" text="Assigned To" prefWidth="140"/>
                    </columns>
                </TableView>
                <HBox styleClass="action-bar" spacing="12" alignment="CENTER_LEFT">
                    <Button fx:id="viewDetailButton" text="View Details" onAction="#handleViewDetail" disable="true"/>
                    <Button fx:id="assignIssueButton" text="Assign Issue" onAction="#handleAssignIssue"
                            styleClass="button-secondary" disable="true"/>
                    <ComboBox fx:id="statusCombo" promptText="Change Status" prefWidth="140"/>
                    <Button fx:id="updateStatusButton" text="Update Status" onAction="#handleUpdateStatus"
                            styleClass="button-secondary" disable="true"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="User Management" closable="false">
            <VBox styleClass="card" spacing="20" style="-fx-padding: 24;">
                <Label text="User Management" styleClass="section-label"/>
                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" prefHeight="400">
                    <columns>
                        <TableColumn fx:id="userIdCol" text="ID" prefWidth="60"/>
                        <TableColumn fx:id="userNameCol" text="Name" prefWidth="200"/>
                        <TableColumn fx:id="userEmailCol" text="Email" prefWidth="280"/>
                        <TableColumn fx:id="userRoleCol" text="Role" prefWidth="120"/>
                    </columns>
                </TableView>
                <HBox styleClass="action-bar" spacing="12" alignment="CENTER_LEFT">
                    <Button fx:id="addUserButton" text="Add User" onAction="#handleAddUser"/>
                    <Button fx:id="editUserButton" text="Approve/Promote Admin" onAction="#handleEditUser"
                            styleClass="button-secondary" disable="true"/>
                    <Button fx:id="deleteUserButton" text="Delete User" onAction="#handleDeleteUser"
                            styleClass="button-danger" disable="true"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Statistics" closable="false">
            <VBox styleClass="card" spacing="24" style="-fx-padding: 24;">

                <!-- Dashboard Metrics Cards -->
                <VBox spacing="16">
                    <Label text="Dashboard Overview" styleClass="section-label"/>
                    <HBox spacing="20" alignment="CENTER_LEFT">
                        <!-- Total Issues Card -->
                        <VBox styleClass="metric-card">
                            <Label text="Total Issues" styleClass="metric-title"/>
                            <Label fx:id="totalIssuesLabel" text="0" styleClass="metric-label"/>
                        </VBox>

                        <!-- Pending Issues Card -->
                        <VBox styleClass="metric-card">
                            <Label text="Pending Issues" styleClass="metric-title"/>
                            <Label fx:id="pendingIssuesLabel" text="0" styleClass="metric-label"/>
                        </VBox>

                        <!-- Resolved Issues Card -->
                        <VBox styleClass="metric-card">
                            <Label text="Resolved Issues" styleClass="metric-title"/>
                            <Label fx:id="resolvedIssuesLabel" text="0" styleClass="metric-label"/>
                        </VBox>

                        <!-- Total Users Card -->
                        <VBox styleClass="metric-card">
                            <Label text="Total Users" styleClass="metric-title"/>
                            <Label fx:id="totalUsersLabel" text="0" styleClass="metric-label"/>
                        </VBox>
                    </HBox>
                </VBox>

                <!-- Category Statistics -->
                <VBox spacing="16">
                    <HBox spacing="12" alignment="CENTER_LEFT">
                        <Label text="Issues by Category" styleClass="section-label"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Button fx:id="refreshStatsButton" text="Refresh" onAction="#handleRefreshStats" styleClass="button-secondary"/>
                    </HBox>
                    <TableView fx:id="categoryStatsTable" prefHeight="250" maxHeight="300" styleClass="table-view">
                        <columns>
                            <TableColumn fx:id="categoryNameCol" text="Category" prefWidth="250"/>
                            <TableColumn fx:id="categoryCountCol" text="Issues Count" prefWidth="150"/>
                        </columns>
                    </TableView>
                </VBox>
            </VBox>
        </Tab>
    </TabPane>
</VBox>