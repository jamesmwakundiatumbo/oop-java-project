<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<VBox xmlns:fx="http://javafx.com/fxml" fx:controller="com.urbanissue.controller.AdminDashboardController"
     spacing="16" prefWidth="800" prefHeight="600">
    <padding><Insets top="16" right="16" bottom="16" left="16"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="12">
        <Label fx:id="welcomeLabel" text="Admin Dashboard" styleClass="welcome-label"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="logoutButton" text="Logout" onAction="#handleLogout"/>
    </HBox>

    <TabPane VBox.vgrow="ALWAYS">
        <Tab text="All Issues" closable="false">
            <VBox spacing="8" style="-fx-padding: 10;">
                <TableView fx:id="issuesTable" VBox.vgrow="ALWAYS" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="idCol" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="titleCol" text="Title" prefWidth="200"/>
                        <TableColumn fx:id="categoryCol" text="Category" prefWidth="120"/>
                        <TableColumn fx:id="statusCol" text="Status" prefWidth="100"/>
                        <TableColumn fx:id="priorityCol" text="Priority" prefWidth="80"/>
                        <TableColumn fx:id="reportedByCol" text="Reported By" prefWidth="150"/>
                        <TableColumn fx:id="assignedCol" text="Assigned To" prefWidth="150"/>
                    </columns>
                </TableView>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button fx:id="viewDetailButton" text="View Details" onAction="#handleViewDetail" disable="true"/>
                    <Button fx:id="assignIssueButton" text="Assign Issue" onAction="#handleAssignIssue" disable="true"/>
                    <ComboBox fx:id="statusCombo" promptText="Change Status" prefWidth="140"/>
                    <Button fx:id="updateStatusButton" text="Update Status" onAction="#handleUpdateStatus" disable="true"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="User Management" closable="false">
            <VBox spacing="8" style="-fx-padding: 10;">
                <TableView fx:id="usersTable" VBox.vgrow="ALWAYS" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="userIdCol" text="ID" prefWidth="50"/>
                        <TableColumn fx:id="userNameCol" text="Name" prefWidth="200"/>
                        <TableColumn fx:id="userEmailCol" text="Email" prefWidth="250"/>
                        <TableColumn fx:id="userRoleCol" text="Role" prefWidth="100"/>
                    </columns>
                </TableView>
                <HBox spacing="8" alignment="CENTER_LEFT">
                    <Button fx:id="addUserButton" text="Add User" onAction="#handleAddUser"/>
                    <Button fx:id="editUserButton" text="Edit User" onAction="#handleEditUser" disable="true"/>
                    <Button fx:id="deleteUserButton" text="Delete User" onAction="#handleDeleteUser" disable="true"/>
                </HBox>
            </VBox>
        </Tab>

        <Tab text="Statistics" closable="false">
            <VBox spacing="16" style="-fx-padding: 10;">
                <Label text="General Statistics" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <GridPane hgap="20" vgap="10">
                    <Label text="Total Issues:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="totalIssuesLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="0"/>

                    <Label text="Pending Issues:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="pendingIssuesLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Resolved Issues:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <Label fx:id="resolvedIssuesLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="2"/>

                    <Label text="Total Users:" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <Label fx:id="totalUsersLabel" text="0" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                </GridPane>

                <Label text="Issues by Category" style="-fx-font-weight: bold; -fx-font-size: 14px;"/>
                <TableView fx:id="categoryStatsTable" prefHeight="200" maxHeight="200">
                    <columns>
                        <TableColumn fx:id="categoryNameCol" text="Category" prefWidth="200"/>
                        <TableColumn fx:id="categoryCountCol" text="Issues Count" prefWidth="100"/>
                    </columns>
                </TableView>

                <Button fx:id="refreshStatsButton" text="Refresh Statistics" onAction="#handleRefreshStats"/>
            </VBox>
        </Tab>
    </TabPane>
</VBox>